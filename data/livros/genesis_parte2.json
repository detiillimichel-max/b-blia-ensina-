    "11": [
      { "v": 1, "texto": "Toda a terra continuava a ter uma só língua e o mesmo vocabulário." },
      { "v": 2, "texto": "Ao viajarem para o leste, os homens descobriram uma planície na terra de Sinear e se estabeleceram ali." },
      { "v": 3, "texto": "E disseram uns aos outros: “Venham! Vamos fazer tijolos e queimá-los no fogo.” Assim, o tijolo lhes servia de pedra, e o betume lhes servia de argamassa." },
      { "v": 4, "texto": "Disseram então: “Venham! Vamos construir uma cidade e uma torre cujo topo chegue aos céus, e façamos um nome célebre para nós, para que não sejamos espalhados por toda a superfície da terra.”" },
      { "v": 5, "texto": "Jeová desceu então para ver a cidade e a torre que os filhos dos homens tinham construído." },
      { "v": 6, "texto": "Jeová disse: “Vejam! Eles são um só povo e todos têm uma só língua, e isso é apenas o começo do que farão. Agora nada do que se propuserem a fazer será impossível para eles.”" },
      { "v": 7, "texto": "“Venham! Desçamos e confundamos ali a língua deles, para que não entendam a língua uns dos outros.”" },
      { "v": 8, "texto": "Assim, Jeová os espalhou dali por toda a superfície da terra, e eles pararam gradualmente de construir a cidade." },
      { "v": 9, "texto": "Por isso ela foi chamada de Babel, porque ali Jeová confundiu a língua de toda a terra, e dali Jeová os espalhou por toda a superfície da terra." },
      { "v": 10, "texto": "Esta é a história de Sem. Sem tinha 100 anos de idade quando se tornou pai de Arpaxade, dois anos depois do dilúvio." },
      { "v": 11, "texto": "Depois de se tornar pai de Arpaxade, Sem viveu 500 anos e se tornou pai de filhos e de filhas." },
      { "v": 12, "texto": "Arpaxade viveu 35 anos e então se tornou pai de Selá." },
      { "v": 13, "texto": "Depois de se tornar pai de Selá, Arpaxade viveu 403 anos e se tornou pai de filhos e de filhas." },
      { "v": 14, "texto": "Selá viveu 30 anos e então se tornou pai de Éber." },
      { "v": 15, "texto": "Depois de se tornar pai de Éber, Selá viveu 403 anos e se tornou pai de filhos e de filhas." },
      { "v": 16, "texto": "Éber viveu 34 anos e então se tornou pai de Pelegue." },
      { "v": 17, "texto": "Depois de se tornar pai de Pelegue, Éber viveu 430 anos e se tornou pai de filhos e de filhas." },
      { "v": 18, "texto": "Pelegue viveu 30 anos e então se tornou pai de Reú." },
      { "v": 19, "texto": "Depois de se tornar pai de Reú, Pelegue viveu 209 anos e se tornou pai de filhos e de filhas." },
      { "v": 20, "texto": "Reú viveu 32 anos e então se tornou pai de Serugue." },
      { "v": 21, "texto": "Depois de se tornar pai de Serugue, Reú viveu 207 anos e se tornou pai de filhos e de filhas." },
      { "v": 22, "texto": "Serugue viveu 30 anos e então se tornou pai de Naor." },
      { "v": 23, "texto": "Depois de se tornar pai de Naor, Serugue viveu 200 anos e se tornou pai de filhos e de filhas." },
      { "v": 24, "texto": "Naor viveu 29 anos e então se tornou pai de Tera." },
      { "v": 25, "texto": "Depois de se tornar pai de Tera, Naor viveu 119 anos e se tornou pai de filhos e de filhas." },
      { "v": 26, "texto": "Tera viveu 70 anos e então se tornou pai de Abrão, de Naor e de Harã." },
      { "v": 27, "texto": "Esta é a história de Tera. Tera tornou-se pai de Abrão, de Naor e de Harã; e Harã tornou-se pai de Ló." },
      { "v": 28, "texto": "Harã morreu enquanto seu pai, Tera, ainda estava vivo, na sua terra natal, em Ur dos caldeus." },
      { "v": 29, "texto": "Abrão e Naor tomaram para si mulheres. O nome da mulher de Abrão era Sarai, e o nome da mulher de Naor era Milca, filha de Harã, que foi pai de Milca e de Iscá." },
      { "v": 30, "texto": "Ora, Sarai era estéril; não tinha filhos." },
      { "v": 31, "texto": "Tera pegou então seu filho Abrão, seu neto Ló, filho de Harã, e sua nora Sarai, mulher do seu filho Abrão, e eles saíram com ele de Ur dos caldeus para ir à terra de Canaã. Com o tempo chegaram a Harã e se estabeleceram ali." },
      { "v": 32, "texto": "Os dias de Tera somaram 205 anos. Então Tera morreu em Harã." }
    ],
    "12": [
      { "v": 1, "texto": "Jeová disse a Abrão: “Saia da sua terra, dos seus parentes e da casa do seu pai, e vá para a terra que eu lhe mostrarei.”" },
      { "v": 2, "texto": "“Farei de você uma grande nação, eu o abençoarei e tornarei o seu nome grande, e você será uma bênção.”" },
      { "v": 3, "texto": "“Abençoarei os que o abençoarem e amaldiçoarei aquele que invocar o mal sobre você, e todas as famílias da terra certamente serão abençoadas por meio de você.”" },
      { "v": 4, "texto": "Abrão partiu, então, assim como Jeová lhe havia dito, e Ló foi com ele. Abrão tinha 75 anos de idade quando partiu de Harã." },
      { "v": 5, "texto": "Abrão levou sua mulher Sarai, seu sobrinho Ló, todos os bens que haviam acumulado e as pessoas que haviam adquirido em Harã, e partiram para a terra de Canaã. Quando chegaram à terra de Canaã," },
      { "v": 6, "texto": "Abrão atravessou a terra até o lugar de Siquém, perto das árvores grandes de Moré. Naquele tempo, os cananeus estavam na terra." },
      { "v": 7, "texto": "Jeová apareceu então a Abrão e disse: “Vou dar esta terra à sua descendência.” De modo que ele construiu ali um altar a Jeová, que lhe havia aparecido." },
      { "v": 8, "texto": "Mais tarde, mudou-se dali para a região montanhosa ao leste de Betel e armou a sua tenda, ficando Betel ao oeste e Ai ao leste. Ali construiu um altar a Jeová e começou a invocar o nome de Jeová." },
      { "v": 9, "texto": "Depois Abrão levantou acampamento, mudando-se de um lugar para outro em direção ao Negebe." },
      { "v": 10, "texto": "Houve então fome na terra, e Abrão desceu ao Egito para morar ali por algum tempo, porque a fome na terra era severa." },
      { "v": 11, "texto": "Quando estava quase entrando no Egito, ele disse à sua mulher Sarai: “Escute, por favor! Sei que você é uma mulher muito bonita.”" },
      { "v": 12, "texto": "“Com certeza, quando os egípcios virem você, dirão: ‘Esta é a mulher dele.’ Então eles me matarão, mas preservarão você viva.”" },
      { "v": 13, "texto": "“Por favor, diga que é minha irmã, para que tudo corra bem comigo por sua causa e a minha vida seja poupada.”" },
      { "v": 14, "texto": "Assim que Abrão entrou no Egito, os egípcios viram que a mulher era de fato muito bonita." },
      { "v": 15, "texto": "Os príncipes do Faraó também a viram e começaram a elogiá-la diante do Faraó, de modo que a mulher foi levada para a casa do Faraó." },
      { "v": 16, "texto": "Ele tratou bem a Abrão por causa dela, e este adquiriu ovelhas, bois, jumentos, servos, servas, jumentas e camelos." },
      { "v": 17, "texto": "Jeová, porém, atingiu o Faraó e a sua casa com grandes pragas, por causa de Sarai, mulher de Abrão." },
      { "v": 18, "texto": "O Faraó chamou então Abrão e disse: “O que foi que você me fez? Por que não me disse que ela era sua mulher?”" },
      { "v": 19, "texto": "“Por que disse: ‘Ela é minha irmã’, deixando que eu a tomasse por esposa? Aqui está a sua mulher. Pegue-a e vá embora!”" },
      { "v": 20, "texto": "E o Faraó deu ordens aos seus homens a respeito dele, e eles o acompanharam até a saída, junto com a sua mulher e tudo o que ele tinha." }
    ],
    "13": [
      { "v": 1, "texto": "Abrão subiu então do Egito para o Negebe — ele, sua mulher e tudo o que tinha, e Ló o acompanhava." },
      { "v": 2, "texto": "Abrão era muito rico em rebanhos, em prata e em ouro." },
      { "v": 3, "texto": "Ele viajou de acampamento em acampamento, desde o Negebe até Betel, até o lugar onde sua tenda estivera antes, entre Betel e Ai," },
      { "v": 4, "texto": "até o lugar onde ele havia construído o altar anteriormente. E ali Abrão invocou o nome de Jeová." },
      { "v": 5, "texto": "Ló, que viajava com Abrão, também tinha ovelhas, bois e tendas." },
      { "v": 6, "texto": "Por isso, a terra não era grande o suficiente para que morassem juntos; os seus bens eram tantos que eles já não podiam morar no mesmo lugar." },
      { "v": 7, "texto": "Em resultado disso, surgiu uma disputa entre os pastores do rebanho de Abrão e os pastores do rebanho de Ló. (Naquele tempo, os cananeus e os perizeus moravam na terra.)" },
      { "v": 8, "texto": "Abrão disse então a Ló: “Por favor, não haja disputa entre mim e você, nem entre os meus pastores e os seus pastores, pois somos irmãos.”" },
      { "v": 9, "texto": "“Não está toda a terra à sua disposição? Por favor, separe-se de mim. Se você for para a esquerda, eu irei para a direita; se você for para a direita, eu irei para a esquerda.”" },
      { "v": 10, "texto": "Ló levantou os olhos e viu que toda a região do Jordão era bem regada (antes de Jeová destruir Sodoma e Gomorra), como o jardim de Jeová, como a terra do Egito, até Zoar." },
      { "v": 11, "texto": "Ló escolheu então para si toda a região do Jordão e mudou o seu acampamento para o leste. Assim eles se separaram um do outro." },
      { "v": 12, "texto": "Abrão morou na terra de Canaã, mas Ló morou entre as cidades daquela região. Por fim, ele armou a sua tenda perto de Sodoma." },
      { "v": 13, "texto": "Ora, os homens de Sodoma eram maus, grandes pecadores contra Jeová." },
      { "v": 14, "texto": "Jeová disse a Abrão, depois que Ló se separou dele: “Levante os olhos, por favor, e olhe desde o lugar onde você está para o norte, para o sul, para o leste e para o oeste;”" },
      { "v": 15, "texto": "“porque toda a terra que você está vendo, eu a darei a você e à sua descendência, como posse permanente.”" },
      { "v": 16, "texto": "“E farei a sua descendência como o pó da terra: se alguém puder contar o pó da terra, a sua descendência também poderá ser contada.”" },
      { "v": 17, "texto": "“Levante-se, percorra a terra no seu comprimento e na sua largura, porque eu a darei a você.”" },
      { "v": 18, "texto": "Abrão continuou, então, a morar em tendas. Mais tarde, mudou-se e foi morar perto das árvores grandes de Manre, que ficam em Hebrom; e ali construiu um altar a Jeová." }
    ],
    "14": [
      { "v": 1, "texto": "No tempo de Anrafel, rei de Sinear, de Arioque, rei de Elasar, de Quedorlaomer, rei de Elam, e de Tidal, rei de Goiim," },
      { "v": 2, "texto": "esses reis fizeram guerra contra Bera, rei de Sodoma, contra Birsa, rei de Gomorra, contra Sinabe, rei de Admá, contra Semeber, rei de Zeboim, e contra o rei de Bela (isto é, Zoar)." },
      { "v": 3, "texto": "Todos estes últimos uniram forças no vale de Sidim (isto é, o mar Salgado)." },
      { "v": 4, "texto": "Eles haviam servido a Quedorlaomer por 12 anos, mas se rebelaram no 13.º ano." },
      { "v": 5, "texto": "No 14.º ano, Quedorlaomer e os reis que estavam com ele vieram e derrotaram os refains em Asterote-Carnaim, os zuzins em Ham, os emins em Save-Quiriataim" },
      { "v": 6, "texto": "e os horeus na sua montanha de Seir, até El-Parã, que fica na entrada do deserto." },
      { "v": 7, "texto": "Depois voltaram, foram a En-Mispate (isto é, Cades) e conquistaram todo o território dos amalequitas, bem como os amorreus que moravam em Hazazom-Tamar." },
      { "v": 8, "texto": "O rei de Sodoma marchou então junto com o rei de Gomorra, o rei de Admá, o rei de Zeboim e o rei de Bela (isto é, Zoar), e eles se alinharam para a batalha contra eles no vale de Sidim," },
      { "v": 9, "texto": "contra Quedorlaomer, rei de Elam, Tidal, rei de Goiim, Anrafel, rei de Sinear, e Arioque, rei de Elasar — quatro reis contra cinco." },
      { "v": 10, "texto": "Ora, o vale de Sidim estava cheio de poços de betume; e os reis de Sodoma e de Gomorra tentaram fugir e caíram neles, e os restantes fugiram para a região montanhosa." },
      { "v": 11, "texto": "Os vencedores levaram então todos os bens de Sodoma e de Gomorra e todos os seus alimentos, e foram embora." },
      { "v": 12, "texto": "Levaram também Ló, sobrinho de Abrão, que morava em Sodoma, junto com os seus bens, e continuaram o seu caminho." },
      { "v": 13, "texto": "Depois, um homem que havia escapado veio e contou isso a Abrão, o hebreu. Ele morava então perto das árvores grandes de Manre, o amorreu, irmão de Escol e irmão de Aner; estes eram aliados de Abrão." },
      { "v": 14, "texto": "Quando Abrão ouviu que o seu parente tinha sido levado cativo, reuniu os seus homens treinados, 318 escravos nascidos na sua casa, e foi em perseguição deles até Dã." },
      { "v": 15, "texto": "Durante a noite, ele dividiu as suas forças, atacou-os com os seus escravos e os derrotou. E os perseguiu até Hobá, que fica ao norte de Damasco." },
      { "v": 16, "texto": "Ele recuperou todos os bens e trouxe de volta também o seu parente Ló, os bens dele, as mulheres e o restante do povo." },
      { "v": 17, "texto": "Depois que Abrão voltou de derrotar Quedorlaomer e os reis que estavam com ele, o rei de Sodoma saiu ao seu encontro no vale de Save (isto é, o vale do Rei)." },
      { "v": 18, "texto": "E Melquisedeque, rei de Salém, trouxe pão e vinho; ele era sacerdote do Deus Altíssimo." },
      { "v": 19, "texto": "Ele o abençoou, dizendo: “Abençoado seja Abrão pelo Deus Altíssimo, Produtor do céu e da terra;”" },
      { "v": 20, "texto": "“e louvado seja o Deus Altíssimo, que entregou os opressores nas suas mãos!” E Abrão lhe deu o dízimo de tudo." },
      { "v": 21, "texto": "O rei de Sodoma disse então a Abrão: “Dê-me as pessoas, mas fique com os bens para você.”" },
      { "v": 22, "texto": "Mas Abrão disse ao rei de Sodoma: “Lanto a minha mão e juro a Jeová, o Deus Altíssimo, Produtor do céu e da terra,”" },
      { "v": 23, "texto": "“que não pegarei nada do que é seu, nem um fio de linha ou uma correia de sandália, para que você não diga: ‘Fui eu que enriqueci Abrão.’”" },
      { "v": 24, "texto": "“Não aceitarei nada, exceto o que os jovens já comeram. E, quanto à parte dos homens que foram comigo — Aner, Escol e Manre —, que eles fiquem com a parte deles.”" }
    ],
    "15": [
      { "v": 1, "texto": "Depois dessas coisas, a palavra de Jeová veio a Abrão numa visão: “Não tenha medo, Abrão. Eu sou o seu escudo. A sua recompensa será muito grande.”" },
      { "v": 2, "texto": "Abrão respondeu: “Soberano Senhor Jeová, o que me darás, visto que continuo sem filhos, e aquele que vai herdar a minha casa é um homem de Damasco, Eliezer?”" },
      { "v": 3, "texto": "Abrão acrescentou: “Não me deste descendência, e um escravo nascido na minha casa é quem me sucederá como herdeiro.”" },
      { "v": 4, "texto": "Mas a palavra de Jeová lhe respondeu: “Esse homem não lhe sucederá como herdeiro; mas o seu próprio filho é quem lhe sucederá como herdeiro.”" },
      { "v": 5, "texto": "Ele o levou para fora e disse: “Olhe para os céus, por favor, e conte as estrelas, se puder.” E lhe disse: “Assim será a sua descendência.”" },
      { "v": 6, "texto": "E ele depositou fé em Jeová, e Ele creditou isso a ele como justiça." },
      { "v": 7, "texto": "Então lhe disse: “Eu sou Jeová, que o tirei de Ur dos caldeus para lhe dar esta terra como posse.”" },
      { "v": 8, "texto": "A isso ele disse: “Soberano Senhor Jeová, como saberei que tomarei posse dela?”" },
      { "v": 9, "texto": "Ele lhe respondeu: “Traga-me uma novilha de três anos, uma cabra de três anos, um carneiro de três anos, uma rola e um pombinho.”" },
      { "v": 10, "texto": "Ele trouxe todos esses animais, partiu-os pelo meio e colocou cada metade em frente da outra; mas não partiu as aves." },
      { "v": 11, "texto": "As aves de rapina começaram a descer sobre os cadáveres, mas Abrão as enxotava." },
      { "v": 12, "texto": "Quando o sol estava para se pôr, Abrão caiu num sono profundo, e uma escuridão profunda e aterrorizante tomou conta dele." },
      { "v": 13, "texto": "Então Deus disse a Abrão: “Saiba com certeza que os seus descendentes serão residentes estrangeiros numa terra que não é deles; e o povo dali os escravizará e os afligirá por 400 anos.”" },
      { "v": 14, "texto": "“Mas eu julgarei a nação à qual servirão como escravos, e depois sairão com muitos bens.”" },
      { "v": 15, "texto": "“Quanto a você, irá para os seus antepassados em paz; será sepultado numa boa velhice.”" },
      { "v": 16, "texto": "“Mas eles voltarão para cá na quarta geração, porque o erro dos amorreus ainda não atingiu a sua medida total.”" },
      { "v": 17, "texto": "Quando o sol se pôs e ficou muito escuro, apareceu um braseiro fumegante, e uma tocha de fogo passou entre os pedaços dos animais." },
      { "v": 18, "texto": "Naquele dia, Jeová fez um pacto com Abrão, dizendo: “À sua descendência darei esta terra, desde o rio do Egito até o grande rio, o rio Eufrates:”" },
      { "v": 19, "texto": "“a terra dos queneus, dos quenezeus, dos cadmoneus,”" },
      { "v": 20, "texto": "“dos hititas, dos perizeus, dos refains,”" },
      { "v": 21, "texto": "“dos amorreus, dos cananeus, dos girgaseus e dos jebuseus.”" }
    ],
    "16": [
      { "v": 1, "texto": "Ora, Sarai, mulher de Abrão, não lhe tinha dado filhos. Mas ela tinha uma serva egípcia chamada Agar." },
      { "v": 2, "texto": "Assim, Sarai disse a Abrão: “Por favor, escute! Jeová me impediu de ter filhos. Por favor, tenha relações com a minha serva. Talvez eu possa ter filhos por meio dela.” E Abrão escutou o que Sarai disse." },
      { "v": 3, "texto": "Depois de Abrão ter morado dez anos na terra de Canaã, Sarai, sua mulher, pegou sua serva egípcia Agar e a deu ao seu marido Abrão por esposa." },
      { "v": 4, "texto": "Ele teve então relações com Agar, e ela engravidou. Quando percebeu que estava grávida, começou a olhar com desprezo para a sua senhora." },
      { "v": 5, "texto": "Sarai disse então a Abrão: “A culpa pela injustiça que estou sofrendo é sua. Fui eu quem colocou a minha serva nos seus braços, mas, assim que ela percebeu que estava grávida, começou a me desprezar. Que Jeová julgue entre mim e você.”" },
      { "v": 6, "texto": "Abrão disse a Sarai: “Olhe, a sua serva está sob a sua autoridade. Faça com ela o que achar melhor.” Sarai começou então a humilhá-la, de modo que Agar fugiu da presença dela." },
      { "v": 7, "texto": "Mais tarde, o anjo de Jeová a encontrou perto de uma fonte de água no deserto, a fonte que fica no caminho de Sur." },
      { "v": 8, "texto": "E ele perguntou: “Agar, serva de Sarai, de onde você vem e para onde vai?” Ela respondeu: “Estou fugindo da presença de Sarai, minha senhora.”" },
      { "v": 9, "texto": "O anjo de Jeová lhe disse então: “Volte para a sua senhora e humilhe-se sob a autoridade dela.”" },
      { "v": 10, "texto": "O anjo de Jeová disse ainda: “Multiplicarei grandemente a sua descendência, de modo que será numerosa demais para ser contada.”" },
      { "v": 11, "texto": "O anjo de Jeová acrescentou: “Você está grávida e dará à luz um filho, e deve lhe dar o nome de Ismael, porque Jeová ouviu a sua aflição.”" },
      { "v": 12, "texto": "“Ele será como um jumento selvagem de homem. A sua mão será contra todos, e a mão de todos será contra eles; e ele morará diante de todos os seus irmãos.”" },
      { "v": 13, "texto": "Então ela invocou o nome de Jeová, que falava com ela, chamando-o de: “Tu és um Deus que vê”, pois disse: “Será que eu realmente olhei aqui para aquele que me vê?”" },
      { "v": 14, "texto": "É por isso que o poço foi chamado de Beer-Laai-Roi. Ele fica entre Cades e Berede." },
      { "v": 15, "texto": "Assim Agar deu à luz um filho a Abrão, e Abrão deu o nome de Ismael ao filho que Agar lhe dera." },
      { "v": 16, "texto": "Abrão tinha 86 anos de idade quando Agar lhe deu Ismael." }
    ],
  "17": [
      { "v": 1, "texto": "Quando Abrão tinha 99 anos de idade, Jeová apareceu a Abrão e lhe disse: “Eu sou o Deus Todo-Poderoso. Ande diante de mim e mostre-se íntegro.”" },
      { "v": 2, "texto": "“Estabelecerei o meu pacto entre mim e você, e eu o multiplicarei grandemente.”" },
      { "v": 3, "texto": "A isso, Abrão prostrou-se com o rosto em terra, e Deus continuou a falar com ele:" },
      { "v": 4, "texto": "“Quanto a mim, o meu pacto é com você, e você certamente se tornará pai de uma multidão de nações.”" },
      { "v": 5, "texto": "“Seu nome não será mais Abrão; seu nome será Abraão, porque farei de você pai de uma multidão de nações.”" },
      { "v": 6, "texto": "“Farei com que você frutifique grandemente e farei de você nações; e reis procederão de você.”" },
      { "v": 7, "texto": "“E cumprirei o meu pacto entre mim e você, e a sua descendência depois de você, de geração em geração, como pacto eterno, para ser o seu Deus e o Deus da sua descendência depois de você.”" },
      { "v": 8, "texto": "“E darei a você e à sua descendência depois de você a terra onde você está morando como estrangeiro, sim, toda a terra de Canaã, como posse permanente; e eu serei o Deus deles.”" },
      { "v": 9, "texto": "Deus disse ainda a Abraão: “Quanto a você, guardará o meu pacto — você e a sua descendência depois de você, de geração em geração.”" },
      { "v": 10, "texto": "“Este é o meu pacto que vocês guardarão, o pacto entre mim e vocês, incluindo a sua descendência depois de você: Todo homem entre vocês terá de ser circuncidado.”" },
      { "v": 11, "texto": "“Vocês devem circuncidar a carne do seu prepúcio, e isso servirá de sinal do pacto entre mim e vocês.”" },
      { "v": 12, "texto": "“De geração em geração, todo menino entre vocês que tiver oito dias de idade terá de ser circuncidado, incluindo qualquer um nascido na casa e qualquer um comprado com dinheiro de um estrangeiro que não seja da sua descendência.”" },
      { "v": 13, "texto": "“Tanto o homem nascido na sua casa como o comprado com o seu dinheiro terão de ser circuncidados; e o meu pacto na carne de vocês servirá de pacto eterno.”" },
      { "v": 14, "texto": "“Se um homem não for circuncidado, ele terá de ser eliminado do seu povo. Ele violou o meu pacto.”" },
      { "v": 15, "texto": "Então Deus disse a Abraão: “Quanto a Sarai, sua mulher, não a chame mais de Sarai, porque o nome dela será Sara.”" },
      { "v": 16, "texto": "“Eu a abençoarei e também lhe darei um filho por meio dela; eu a abençoarei e ela se tornará nações; reis de povos procederão dela.”" },
      { "v": 17, "texto": "A isso Abraão prostrou-se com o rosto em terra e começou a rir, dizendo no seu coração: “Será que nascerá um filho a um homem de 100 anos de idade, e será que Sara, uma mulher de 90 anos, dará à luz?”" },
      { "v": 18, "texto": "Abraão disse então ao verdadeiro Deus: “Se apenas Ismael pudesse viver diante de ti!”" },
      { "v": 19, "texto": "A isso Deus disse: “Sua mulher Sara certamente lhe dará à luz um filho, e você deve lhe dar o nome de Isaque. E estabelecerei o meu pacto com ele, como pacto eterno para a sua descendência depois de ele.”" },
      { "v": 20, "texto": "“Mas, quanto a Ismael, eu o ouvi. Eu o abençoarei, farei com que frutifique e o multiplicarei grandemente. Ele produzirá 12 maiorais, e farei dele uma grande nação.”" },
      { "v": 21, "texto": "“No entanto, estabelecerei o meu pacto com Isaque, que Sara dará à luz a você no ano que vem, por este tempo.”" },
      { "v": 22, "texto": "Quando terminou de falar com ele, Deus subiu, retirando-se de Abraão." },
      { "v": 23, "texto": "Abraão pegou então seu filho Ismael, todos os homens nascidos na sua casa e todos os que tinham sido comprados com o seu dinheiro, todo homem da casa de Abraão, e circuncidou a carne do prepúcio deles naquele exato dia, conforme Deus lhe havia dito." },
      { "v": 24, "texto": "Abraão tinha 99 anos de idade quando foi circuncidado." },
      { "v": 25, "texto": "E seu filho Ismael tinha 13 anos de idade quando foi circuncidado." },
      { "v": 26, "texto": "Naquele exato dia Abraão foi circuncidado, e também seu filho Ismael." },
      { "v": 27, "texto": "E todos os homens da sua casa — os nascidos na casa e os comprados com dinheiro de um estrangeiro — foram circuncidados com ele." }
    ],
    "18": [
      { "v": 1, "texto": "Mais tarde, Jeová apareceu a ele entre as árvores grandes de Manre, enquanto ele estava sentado à entrada da tenda, na hora mais quente do dia." },
      { "v": 2, "texto": "Ele levantou os olhos e viu três homens em pé, a alguma distância dele. Assim que os viu, correu da entrada da tenda ao encontro deles e curvou-se até o chão." },
      { "v": 3, "texto": "Então disse: “Jeová, se achei favor aos teus olhos, por favor, não passes pelo teu servo sem parar.”" },
      { "v": 4, "texto": "“Por favor, tragam um pouco de água para lavar os pés de vocês; e descansem debaixo da árvore.”" },
      { "v": 5, "texto": "“Visto que vieram aqui ao seu servo, deixem-me trazer um pouco de pão para que recuperem as forças. Depois poderão continuar o seu caminho.” A isso eles disseram: “Está bem. Pode fazer como disse.”" },
      { "v": 6, "texto": "Abraão correu então para a tenda, para junto de Sara, e disse: “Depressa! Pegue três medidas da melhor farinha, amasse-a e faça pães.”" },
      { "v": 7, "texto": "Em seguida, Abraão correu ao rebanho, escolheu um novilho bom e tenro e o deu ao servo, que se apressou em prepará-lo." },
      { "v": 8, "texto": "Pegou então manteiga, leite e o novilho que havia preparado e pôs tudo diante deles. Ele mesmo ficou em pé junto deles, debaixo da árvore, enquanto comiam." },
      { "v": 9, "texto": "Eles lhe perguntaram: “Onde está Sara, sua mulher?” Ele respondeu: “Está ali na tenda.”" },
      { "v": 10, "texto": "Então um deles disse: “Certamente voltarei a você no ano que vem, por este tempo, e Sara, sua mulher, terá um filho.” Ora, Sara estava escutando à entrada da tenda, que estava atrás dele." },
      { "v": 11, "texto": "Abraão e Sara já eram velhos, de idade bem avançada; e Sara já tinha passado da idade de ter filhos." },
      { "v": 12, "texto": "Por isso, Sara começou a rir no seu íntimo, dizendo: “Agora que estou velha e o meu senhor também está velho, terei eu realmente esse prazer?”" },
      { "v": 13, "texto": "Jeová perguntou então a Abraão: “Por que Sara riu e disse: ‘Será que darei mesmo à luz, agora que estou velha?’”" },
      { "v": 14, "texto": "“Há alguma coisa que seja extraordinária demais para Jeová? No tempo determinado voltarei a você, no ano que vem por este tempo, e Sara terá um filho.”" },
      { "v": 15, "texto": "Mas Sara negou, dizendo: “Eu não ri!” Pois estava com medo. Mas ele disse: “Não minta, você riu sim.”" },
      { "v": 16, "texto": "Quando os homens se levantaram para ir embora e olharam lá de cima para Sodoma, Abraão foi caminhando com eles para os acompanhar." },
      { "v": 17, "texto": "Jeová disse: “Esconderei eu de Abraão o que estou para fazer?”" },
      { "v": 18, "texto": "“Visto que Abraão certamente se tornará uma grande e poderosa nação, e todas as nações da terra serão abençoadas por meio dele?”" },
      { "v": 19, "texto": "“Porque eu o escolhi para que ordene aos seus filhos e à sua casa depois dele que guardem o caminho de Jeová, fazendo o que é justo e direito, a fim de que Jeová cumpra o que prometeu a Abraão.”" },
      { "v": 20, "texto": "Jeová disse então: “O clamor contra Sodoma e Gomorra é grande de fato, e o pecado deles é muito grave.”" },
      { "v": 21, "texto": "“Vou descer para ver se eles agem totalmente de acordo com o clamor que chegou até mim. E, se não for assim, ficarei sabendo.”" },
      { "v": 22, "texto": "Os homens se retiraram dali e foram em direção a Sodoma, mas Jeová permaneceu com Abraão." },
      { "v": 23, "texto": "Abraão aproximou-se então e disse: “Destruirás realmente o justo junto com o mau?”" },
      { "v": 24, "texto": "“Suponhamos que haja 50 justos na cidade. Destruirás o lugar e não o perdoarás por causa dos 50 justos que estão nela?”" },
      { "v": 25, "texto": "“É inconcebível que ajas de tal maneira, matando o justo junto com o mau, de modo que o justo receba o mesmo que o mau! É inconcebível! Não fará o Juiz de toda a terra o que é justo?”" },
      { "v": 26, "texto": "Jeová respondeu: “Se eu achar em Sodoma 50 justos dentro da cidade, perdoarei o lugar inteiro por causa deles.”" },
      { "v": 27, "texto": "Mas Abraão disse ainda: “Por favor, visto que me atrevi a falar a Jeová, embora eu seja pó e cinza:”" },
      { "v": 28, "texto": "“Suponhamos que dos 50 justos faltem cinco. Destruirás a cidade inteira por causa dos cinco?” Ele respondeu: “Não a destruirei se achar ali 45.”" },
      { "v": 29, "texto": "Mas ele Lhe falou mais uma vez: “Suponhamos que se achem ali 40.” Ele respondeu: “Não o farei por causa dos 40.”" },
      { "v": 30, "texto": "Mas ele continuou: “Por favor, não fiques irado, Jeová, mas deixa-me continuar falando: Suponhamos que se achem ali 30.” Ele respondeu: “Não o farei se achar ali 30.”" },
      { "v": 31, "texto": "Mas ele continuou: “Por favor, visto que me atrevi a falar a Jeová: Suponhamos que se achem ali 20.” Ele respondeu: “Não a destruirei por causa dos 20.”" },
      { "v": 32, "texto": "Por fim ele disse: “Por favor, não fiques irado, Jeová, mas deixa-me falar só mais esta vez: Suponhamos que se achem ali dez.” Ele respondeu: “Não a destruirei por causa dos dez.”" },
      { "v": 33, "texto": "Quando terminou de falar com Abraão, Jeová foi embora, e Abraão voltou para o seu lugar." }
    ],
    "19": [
      { "v": 1, "texto": "Os dois anjos chegaram a Sodoma ao anoitecer, e Ló estava sentado à porta de Sodoma. Quando Ló os viu, levantou-se para ir ao encontro deles e curvou-se com o rosto até o chão." },
      { "v": 2, "texto": "E disse: “Por favor, meus senhores, entrem na casa do seu servo, passem a noite ali e lavem os pés. Depois poderão se levantar cedo e continuar o seu caminho.” A isso eles disseram: “Não, passaremos a noite na praça pública.”" },
      { "v": 3, "texto": "Mas ele insistiu tanto com eles que eles foram e entraram na casa dele. Ele preparou então um banquete para eles e assou pães sem fermento, e eles comeram." },
      { "v": 4, "texto": "Antes de eles se deitarem, os homens da cidade, os homens de Sodoma — desde o rapaz até o velho, todo o povo em massa —, cercaram a casa." },
      { "v": 5, "texto": "E chamavam Ló e lhe perguntavam: “Onde estão os homens que vieram à sua casa esta noite? Traga-os para fora, para que tenhamos relações com eles.”" },
      { "v": 6, "texto": "Ló saiu então ao encontro deles à porta, fechou a porta atrás de si" },
      { "v": 7, "texto": "e disse: “Por favor, meus irmãos, não façam essa maldade.”" },
      { "v": 8, "texto": "“Por favor, olhem! Tenho duas filhas que nunca tiveram relações com homem. Deixem-me trazê-las para fora para vocês, e façam com elas o que acharem melhor. Mas não façam nada a esses homens, porque vieram se abrigar sob o meu teto.”" },
      { "v": 9, "texto": "A isso eles disseram: “Saia da frente!” E acrescentaram: “Este homem veio aqui como estrangeiro e agora quer agir como juiz! Faremos a você pior do que a eles.” E começaram a empurrar Ló com violência e avançaram para arrombar a porta." },
      { "v": 10, "texto": "Os homens dentro da casa estenderam então as mãos, puxaram Ló para dentro e fecharam a porta." },
      { "v": 11, "texto": "Mas feriram de cegueira os homens que estavam à porta da casa, desde o menor até o maior, de modo que se cansaram de tentar achar a porta." },
      { "v": 12, "texto": "Os homens perguntaram então a Ló: “Você tem mais alguém aqui? Genros, filhos, filhas ou qualquer outro parente na cidade, tire-os deste lugar!”" },
      { "v": 13, "texto": "“Porque vamos destruir este lugar, visto que o clamor contra eles se tornou grande diante de Jeová, de modo que Jeová nos enviou para destruir a cidade.”" },
      { "v": 14, "texto": "Ló saiu então e foi falar com os seus genros, que iam se casar com as suas filhas, dizendo: “Depressa! Saiam deste lugar, porque Jeová vai destruir a cidade!” Mas para os seus genros parecia que ele estava brincando." },
      { "v": 15, "texto": "Ao amanhecer, os anjos começaram a apressar Ló, dizendo: “Depressa! Pegue sua mulher e suas duas filhas que estão aqui, para que não sejam eliminados por causa do erro da cidade!”" },
      { "v": 16, "texto": "Visto que ele continuava a demorar, os homens pegaram a sua mão, a mão da sua mulher e as mãos das suas duas filhas, porque Jeová teve compaixão dele; e os tiraram dali e os deixaram fora da cidade." },
      { "v": 17, "texto": "Assim que os tiraram dali, um deles disse: “Fuja para salvar a sua vida! Não olhe para trás e não pare em nenhum lugar desta região! Fuja para a região montanhosa, para que não seja eliminado!”" },
      { "v": 18, "texto": "Ló lhes disse então: “Não para lá, por favor, Jeová!”" },
      { "v": 19, "texto": "“O teu servo achou favor aos teus olhos, e tu estás demonstrando grande bondade para comigo, preservando a minha vida. Mas eu não posso fugir para a região montanhosa, com medo de que o desastre me alcance e eu morra.”" },
      { "v": 20, "texto": "“Por favor, olhe! Aquela cidade está perto para fugir para lá, e é um lugar pequeno. Por favor, posso fugir para lá? Não é um lugar bem pequeno? Assim a minha vida será salva.”" },
      { "v": 21, "texto": "Então ele lhe disse: “Está bem, concederei a você também este favor: não destruirei a cidade de que você falou.”" },
      { "v": 22, "texto": "“Fuja depressa para lá, porque não posso fazer nada até que você chegue ali!” É por isso que a cidade foi chamada de Zoar." },
      { "v": 23, "texto": "O sol já havia nascido sobre a terra quando Ló chegou a Zoar." },
      { "v": 24, "texto": "Jeová fez então chover enxofre e fogo sobre Sodoma e Gomorra; isso veio da parte de Jeová, desde os céus." },
      { "v": 25, "texto": "Assim ele destruiu essas cidades, sim, toda a região, todos os habitantes das cidades e a vegetação do solo." },
      { "v": 26, "texto": "Mas a mulher de Ló, que estava atrás dele, começou a olhar para trás e se tornou uma coluna de sal." },
      { "v": 27, "texto": "Abraão levantou-se cedo de manhã e foi ao lugar onde havia estado diante de Jeová." },
      { "v": 28, "texto": "Quando olhou para baixo, em direção a Sodoma e Gomorra e a toda a terra daquela região, viu fumaça subindo da terra, como a fumaça grossa de uma fornalha!" },
      { "v": 29, "texto": "Assim, quando Deus destruiu as cidades daquela região, Deus se lembrou de Abraão e tirou Ló do meio da destruição, ao destruir as cidades onde Ló morava." },
      { "v": 30, "texto": "Mais tarde, Ló saiu de Zoar e passou a morar na região montanhosa junto com as suas duas filhas, pois estava com medo de morar em Zoar. Assim, passou a morar numa caverna, ele e as suas duas filhas." },
      { "v": 31, "texto": "A primogênita disse à mais jovem: “Nosso pai é velho, e não há nenhum homem nesta terra para ter relações conosco, conforme o costume de toda a terra.”" },
      { "v": 32, "texto": "“Venha, vamos dar vinho ao nosso pai e nos deitar com ele, para preservar a descendência do nosso pai.”" },
      { "v": 33, "texto": "De modo que deram vinho ao seu pai naquela noite; a primogênita entrou então e se deitou com o seu pai, mas ele não percebeu nem quando ela se deitou nem quando se levantou." },
      { "v": 34, "texto": "No dia seguinte, a primogênita disse à mais jovem: “Ontem à noite eu me deitei com o meu pai. Vamos dar-lhe vinho também esta noite. Entra e deita-te com ele, para preservarmos a descendência do nosso pai.”" },
      { "v": 35, "texto": "Assim, deram vinho ao seu pai também naquela noite; a mais jovem foi então e se deitou com ele, mas ele não percebeu nem quando ela se deitou nem quando se levantou." },
      { "v": 36, "texto": "Desse modo, as duas filhas de Ló engravidaram do seu próprio pai." },
      { "v": 37, "texto": "A primogênita deu à luz um filho e lhe deu o nome de Moabe. Ele é o pai dos moabitas de hoje." },
      { "v": 38, "texto": "A mais jovem também deu à luz um filho e lhe deu o nome de Ben-Ami. Ele é o pai dos amonitas de hoje." }
    ],
    "20": [
      { "v": 1, "texto": "Abraão levantou acampamento dali e foi para a região do Negebe, e passou a morar entre Cades e Sur. Enquanto morava por algum tempo em Gerar," },
      { "v": 2, "texto": "Abraão dizia a respeito de sua mulher Sara: “Ela é minha irmã.” Abimeleque, rei de Gerar, mandou então buscar Sara e a tomou." },
      { "v": 3, "texto": "Depois, Deus veio a Abimeleque num sonho, à noite, e lhe disse: “Você vai morrer por causa da mulher que tomou, visto que ela é casada.”" },
      { "v": 4, "texto": "No entanto, Abimeleque não se havia aproximado dela. De modo que disse: “Jeová, destruirás uma nação que é de fato inocente?”" },
      { "v": 5, "texto": "“Não foi ele mesmo quem me disse: ‘Ela é minha irmã’? E ela mesma não disse: ‘Ele é meu irmão’? Fiz isso com integridade de coração e com mãos inocentes.”" },
      { "v": 6, "texto": "O verdadeiro Deus lhe disse então no sonho: “Eu sei que você fez isso com integridade de coração, e fui eu quem o impediu de pecar contra mim. É por isso que não permiti que você a tocasse.”" },
      { "v": 7, "texto": "“Agora, devolva a mulher do homem, pois ele é profeta; ele intercederá por você e você continuará vivo. Mas, se não a devolver, saiba com certeza que você morrerá, você e todos os seus.”" },
      { "v": 8, "texto": "Abimeleque levantou-se de manhã cedo, chamou todos os seus servos e lhes contou tudo o que havia acontecido; e os homens ficaram com muito medo." },
      { "v": 9, "texto": "Abimeleque chamou então Abraão e lhe disse: “O que foi que você nos fez? Que pecado cometi contra você, para que trouxesse um pecado tão grande sobre mim e sobre o meu reino? O que você me fez não devia ser feito.”" },
      { "v": 10, "texto": "Abimeleque perguntou ainda a Abraão: “Qual era a sua intenção ao fazer isso?”" },
      { "v": 11, "texto": "Abraão respondeu: “É porque pensei: ‘Com certeza não há temor de Deus neste lugar, e eles me matarão por causa da minha mulher.’”" },
      { "v": 12, "texto": "“Além disso, ela é realmente minha irmã, filha do meu pai, mas não da minha mãe; e ela se tornou minha mulher.”" },
      { "v": 13, "texto": "“Por isso, quando Deus me fez peregrinar longe da casa do meu pai, eu lhe disse: ‘Esta é a demonstração de amor leal que você fará por mim: Em todo lugar onde chegarmos, diga a meu respeito: “Ele é meu irmão.”’”" },
      { "v": 14, "texto": "Abimeleque pegou então ovelhas, bois, servos e servas e os deu a Abraão, e lhe devolveu sua mulher Sara." },
      { "v": 15, "texto": "Abimeleque disse ainda: “Minha terra está à sua disposição. More onde achar melhor.”" },
      { "v": 16, "texto": "E a Sara ele disse: “Estou dando 1.000 moedas de prata ao seu irmão. Isso serve para cobrir os olhos de todos os que estão com você, de modo que você está plenamente justificada diante de todos.”" },
      { "v": 17, "texto": "Abraão começou então a interceder junto ao verdadeiro Deus, e Deus curou Abimeleque, sua mulher e suas servas, de modo que começaram a ter filhos;" },
      { "v": 18, "texto": "porque Jeová havia tornado estéreis todas as mulheres da casa de Abimeleque, por causa de Sara, mulher de Abraão." }
    ]
